# =============================================================================
# PLD-Master Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the actual values.
# Never commit .env.local to git (it contains secrets).
# For Vercel deployments, set these in the project settings dashboard.
# =============================================================================

# SUPABASE (Database & Authentication)
# =============================================================================
# Get these from Supabase Dashboard > Project Settings > API

# Supabase project URL (e.g., https://xyzabc.supabase.co)
# Used by: supabase client (browser + server), seed script
# Find at: Supabase Dashboard > Project Settings > API > Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anonymous/public key (safe to expose to browser)
# Used by: browser client for auth & database queries
# Find at: Supabase Dashboard > Project Settings > API > anon key
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase service role key (SECRET - server-side only)
# Used by: /api/* endpoints for admin operations (bypasses RLS)
# Used by: seed script to ingest global documents
# Find at: Supabase Dashboard > Project Settings > API > service_role key
# WARNING: Never expose this to the browser or client-side code
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# =============================================================================
# AI & LLM APIs
# =============================================================================

# Google Generative AI (Gemini) API Key
# Used by: /api/chat (AI tutor), /api/generate-quiz, seed script (embeddings)
# Models: gemini-1.5-pro (complex reasoning), gemini-1.5-flash (fast chat), text-embedding-004 (vectors)
# Get at: https://ai.google.dev/gemini-api/docs/api-key
GEMINI_API_KEY=AIza...

# Anthropic Claude API Key (optional)
# Used by: future features or as fallback AI provider
# Get at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API Key (optional)
# Used by: future features or as fallback provider
# Get at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# =============================================================================
# GOOGLE DRIVE API (Document Ingestion)
# =============================================================================
# Used by: /api/ingest-drive, /api/list-drive-folder, seed script
# Needed to list and download PDFs from Google Drive folders
# Get at: Google Cloud Console > APIs & Services > Credentials > API Keys
# Restrict to: Google Drive API v3
GOOGLE_DRIVE_API_KEY=AIza...

# =============================================================================
# STRIPE (Payments & Subscriptions)
# =============================================================================

# Stripe Secret API Key (SECRET - server-side only)
# Used by: /api/checkout (create sessions), /api/webhook (handle events)
# Find at: Stripe Dashboard > Developers > API Keys > Secret Key
# WARNING: Never expose to browser
STRIPE_SECRET_KEY=sk_live_... or sk_test_... for testing

# Stripe Webhook Signing Secret (SECRET - server-side only)
# Used by: /api/webhook to verify Stripe signature
# Find at: Stripe Dashboard > Developers > Webhooks > Signing Secret
# Set webhook endpoint to: https://your-domain.com/api/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# =============================================================================
# SECURITY & CONFIGURATION
# =============================================================================

# Admin Secret Key (SECRET - server-side only)
# Used by: /api/admin/* endpoints to restrict access
# Must match header value sent by admin client
ADMIN_SECRET_KEY=super-secret-admin-key-change-in-production

# Seed Script Secret (optional)
# Extra security layer for seed operations
# Used by: scripts/seed-global-documents.mjs
SEED_SECRET=seed-secret-key

# Public Site URL (used for Stripe redirects, Google OAuth callback)
# Local development: http://localhost:3000
# Production: https://your-domain.com (Vercel URL)
# Used by: /api/checkout (return URL), auth redirects
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# =============================================================================
# DEPLOYMENT NOTES
# =============================================================================
#
# For local development:
#   1. Copy this file to .env.local
#   2. Fill in actual API keys
#   3. Run: npm run dev
#
# For Vercel:
#   1. Go to Vercel Dashboard > Project Settings > Environment Variables
#   2. Add each variable above (don't include comments)
#   3. Keep NEXT_PUBLIC_* for browser-readable vars
#   4. Keep others as server-only secrets
#   5. Deploy → Vercel will inject variables at build time
#
# Database:
#   - Supabase automatically applies schema from supabase/schema.sql
#   - To seed 18 official CNBV PDFs: npm run seed (requires .env.local)
#
# Testing:
#   - Use Stripe test keys (sk_test_..., pk_test_...) for checkout testing
#   - Stripe test card: 4242 4242 4242 4242 (any future date, any CVC)
#   - Use Google Drive test folder with public PDFs
#
# =============================================================================
